# =============================================================================
# Event Edge Bot 2k — environment template (copy to .env; never commit .env)
# =============================================================================

# --- App ---
APP_ENV=development
# mock | market_data | full_analysis
APP_MODE=mock
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./stonks.db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS origin for Vite dev server
FRONTEND_ORIGIN=http://localhost:5173

# --- Paper / risk defaults (override in .env as needed) ---
BOT_DEFAULT_STARTING_CASH=2000
BOT_DEFAULT_MAX_RISK_PER_TRADE_PCT=1
BOT_DEFAULT_MAX_DAILY_LOSS_PCT=5
BOT_DEFAULT_MAX_WEEKLY_LOSS_PCT=8
BOT_DEFAULT_MAX_OPEN_POSITIONS=2
BOT_DEFAULT_MAX_OPEN_POSITIONS_PER_SYMBOL=1
BOT_DEFAULT_APPROVED_UNIVERSE=SPY,QQQ,IWM,XLF,XLK,TLT,SLV
# No new positions in last N minutes before regular session close (ET)
BOT_NO_NEW_TRADES_MINUTES_BEFORE_CLOSE=30
# Optional: allow second concurrent position when set to 2
# BOT_DEFAULT_MAX_OPEN_POSITIONS=2
# Minutes to pause after a realized loss (0 = disabled)
BOT_LOSS_COOLDOWN_MINUTES=0
# Allow range credit_spread candidates when regime is range (default off)
ENABLE_RANGE_CREDIT_SPREAD=false
# Paper fill simulation
PAPER_SLIPPAGE_BPS=5
PAPER_PARTIAL_FILL_MAX_FRACTION=0.5
PAPER_FEE_PER_CONTRACT=0
PAPER_NORMAL_RISK_TIER_PCT=1.0
PAPER_STRONG_RISK_TIER_PCT=1.5
PAPER_MAX_RISK_TIER_PCT=2.0
PAPER_MAX_COMBINED_OPEN_RISK_PCT=3.0
PAPER_DAILY_DRAWDOWN_STOP_PCT=5.0
PAPER_STOP_NEW_ENTRIES_AFTER_LOSSES=3
PAPER_RECOMMENDATION_MAX_PER_DAY=3
PAPER_RECOMMENDATION_MAX_PER_SYMBOL_PER_DAY=1

# --- OpenAI primary reasoning (Responses API) ---
AI_PROVIDER=openai
OPENAI_ENABLED=true
XAI_ENABLED=false
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
OPENAI_TRIAGE_MODEL=gpt-5.4-mini
OPENAI_ESCALATION_MODEL=gpt-5.4
OPENAI_REQUEST_TIMEOUT_SECONDS=120
OPENAI_ENABLE_REAL_CALLS=false
USE_MOCK_OPENAI=true

# --- xAI optional sidecar enrichment (X/social context only) ---
XAI_API_KEY=
XAI_API_BASE_URL=https://api.x.ai/v1
XAI_REQUEST_TIMEOUT_SECONDS=120
XAI_ENABLE_REAL_CALLS=false
XAI_ENRICHMENT_MODEL=grok-4.1-fast
XAI_ENABLE_X_SEARCH_ENRICHMENT=false
V1_DISABLE_XAI_RUNTIME=true
XAI_ENRICHMENT_MAX_CALLS_PER_DAY=25
XAI_ENRICHMENT_MIN_MATERIALITY_SCORE=60
XAI_ENRICHMENT_SYMBOL_ALLOWLIST=SPY,QQQ,IWM,XLF,XLK,TLT,SLV
XAI_ENRICHMENT_EVENT_TYPES=earnings,sec_filing,macro_announcement,headline,guidance_change,transcript,other
USE_MOCK_XAI=true

# --- Tastytrade / broker (market data & future live) ---
TASTYTRADE_API_BASE_URL=https://api.tastytrade.com
TASTYTRADE_DX_URL=wss://feed.dxfeed.com/dxlink-ws
TASTYTRADE_OAUTH_CLIENT_ID=
TASTYTRADE_OAUTH_CLIENT_SECRET=
TASTYTRADE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth/callback
TASTYTRADE_REFRESH_TOKEN=
TASTYTRADE_ACCOUNT_NUMBER=
# Sandbox flag exists for broker API; local paper simulator is always primary
TASTYTRADE_USE_SANDBOX=false

# --- Events / news providers ---
USE_MOCK_EVENTS=true
NEWS_PROVIDER=mock
NEWS_API_KEY=
THENEWSAPI_API_KEY=
THENEWSAPI_ENABLE_REAL_CALLS=false
THENEWSAPI_REQUEST_LIMIT_PER_DAY=100
SEC_USER_AGENT=StonksPaperBot/1.0 (contact@example.com)
EARNINGS_PROVIDER=mock
TRANSCRIPT_PROVIDER=mock

# --- SPY 0DTE scalper (Strategy 2, isolated ledger) ---
SPY_SCALPER_PAPER_ONLY=true
SPY_SCALPER_JOB_INTERVAL_SECONDS=60
SPY_SCALPER_RECON_INTERVAL_SECONDS=60
SPY_SCALPER_RESERVE_CASH=1000
SPY_SCALPER_DEPLOYABLE_TARGET=4000
SPY_SCALPER_MAX_TRADES_PER_DAY=15
SPY_SCALPER_MAX_CONSECUTIVE_LOSSES=3
SPY_SCALPER_PRE_AI_MIN_SCORE=60
SPY_SCALPER_AI_MAX_CALLS_PER_DAY=30
SPY_SCALPER_CONTRACT_DELTA_MIN=0.45
SPY_SCALPER_CONTRACT_DELTA_MAX=0.60
SPY_SCALPER_PREMIUM_TARGET_MIN=150
SPY_SCALPER_PREMIUM_TARGET_MAX=250
SPY_SCALPER_PREMIUM_HARD_MAX=300
SPY_SCALPER_MAX_HOLD_MINUTES=8
SPY_SCALPER_FAST_FAIL_MINUTES=3
SPY_SCALPER_COOLDOWN_AFTER_EXIT_SECONDS=60
SPY_SCALPER_COOLDOWN_AFTER_FAST_LOSER_SECONDS=120
SPY_SCALPER_DAILY_HARD_STOP_LOSS=500
SPY_SCALPER_DAILY_SOFT_STOP_LOSS=300
SPY_SCALPER_LIMIT_OFFSET_FROM_MID=0.02
SPY_SCALPER_CANCEL_WINDOW_SECONDS=45
SPY_SCALPER_SLIPPAGE_BPS=8

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=Stonks
VITE_REFRESH_INTERVAL_MS=5000

# --- Debug (optional) ---
# When true, GET /debug/market-data exposes QuoteCache + latest snapshots (also allowed when APP_ENV=development).
MARKET_DEBUG_ENDPOINT_ENABLED=false
